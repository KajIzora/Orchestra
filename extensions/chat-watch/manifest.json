{
  "manifest_version": 3,
  "name": "Orchestra Chat Watch",
  "version": "0.3.0",
  "description": "Syncs ChatGPT, Claude, and Gemini tab state to Orchestra for browser chat watching.",
  "permissions": ["activeTab", "tabs", "storage", "webRequest"],
  "host_permissions": [
    "https://chatgpt.com/*",
    "https://chat.openai.com/*",
    "https://claude.ai/*",
    "https://gemini.google.com/*",
    "http://127.0.0.1/*",
    "http://localhost/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*",
        "https://claude.ai/*",
        "https://gemini.google.com/*"
      ],
      "js": [
        "spoofer.js"
      ],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*",
        "https://claude.ai/*",
        "https://gemini.google.com/*"
      ],
      "js": [
        "privacy-settings.js",
        "gemini-watch-signals.js",
        "claude-watch-signals.js",
        "content-chatgpt.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "Orchestra Chat Watch",
    "default_popup": "popup.html"
  }
}
